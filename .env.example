# ══════════════════════════════════════════════
# Cabinet Studio — Environment Variables
# Copy to .env and update values
# ══════════════════════════════════════════════

# Database (local MariaDB)
DB_HOST=localhost
DB_PORT=3306
DB_USER=cabinet
DB_PASS=cabinet
DB_NAME=cabinet_studio
DB_ROOT_PASS=change-this-root-password

# Auth
JWT_SECRET=generate-a-64-char-random-string-here-use-openssl-rand-hex-32

# Server
PORT=3001
CORS_ORIGIN=https://cab.badvolf.ru

# Node
NODE_ENV=production
